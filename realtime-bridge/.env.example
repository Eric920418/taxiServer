# bridge.mjs 環境變數範本
# 實際值放 box:/opt/taxi-ai-bridge/.env（chmod 600，勿進版控；.gitignore 已擋 .env）
OPENAI_API_KEY=sk-proj-xxxxxxxx          # OpenAI Realtime API key
BRIDGE_SECRET=xxxxxxxx                    # 須與後端 .env 的 BRIDGE_SECRET 一致（realtime-order 驗證）
BACKEND_URL=https://api.hualientaxi.taxi
RT_MODEL=gpt-realtime
VOICE=marin
MAX_CALLS=3                              # 即時 AI 並發上限（與 dialplan taxi-route 的 GROUP_COUNT 閘門一致）
SERVICE_PHONE=                           # 轉真人客服的號碼（AI 處理不了時轉接）；fet-outbound 能撥的格式：手機 09xxxxxxxx 或市話 03xxxxxxx。留空=不轉接

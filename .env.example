# 伺服器設定
NODE_ENV=development
PORT=3000

# 資料庫設定
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hualien_taxi
DB_USER=postgres
DB_PASSWORD=

# 資料庫連線池優化設定
DB_POOL_MAX=50
DB_POOL_MIN=10

# Redis 快取設定
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 設定
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h

# CORS 設定
CORS_ORIGIN=*

# 日誌設定
LOG_LEVEL=debug

# Rate Limiting 設定（選填）
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Socket.io 設定（選填）
# SOCKET_PING_TIMEOUT=60000
# SOCKET_PING_INTERVAL=25000

# 檔案上傳限制
# MAX_FILE_SIZE=10mb
# MAX_REQUEST_SIZE=10mb

# API Key（選填，用於第三方服務）
# GOOGLE_MAPS_API_KEY=
# FIREBASE_API_KEY=

# 監控和分析（選填）
# SENTRY_DSN=
# ANALYTICS_ID=

# ============================================
# 客人反向通知 — PR1 基礎建設
# 接入流程於 PR2 啟用
# ============================================

# 三竹簡訊（Mitake）— 客人無 LINE 時的備援通知
# 測試端點（不扣費）：https://smexpress.mitake.com.tw:9601/SmSendGetSim.asp
# 正式端點：         https://smexpress.mitake.com.tw:9601/SmSendGet.asp
MITAKE_SMS_USERNAME=
MITAKE_SMS_PASSWORD=
MITAKE_SMS_API_URL=https://smexpress.mitake.com.tw:9601/SmSendGetSim.asp

# 客服電話（會放進通知訊息的「請致電 xxx」變數）
CUSTOMER_SERVICE_PHONE=03-000-0000

# Feature flag — 通知分派器啟用開關（PR2 生效）
# 設 true 後 CustomerNotificationService 才會真的發送；設 false 秒級關閉所有對外通知
CUSTOMER_NOTIFICATION_ENABLED=false

# 測試專用（跑 scripts/test-sms-notifier.ts 時使用）
# TEST_PHONE=0912345678
# FORCE_REAL_SEND=1  # 若 API URL 為正式端點需加此旗標才會發送
